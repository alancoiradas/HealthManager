        height: 90dvh;
        background-image: url("/Media/Images/reserve-appointment.jpg");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        
    }

    .image-container::before{

            content: "";
            position: relative;
            inset: 0;
            background-color: rgba(0, 0, 0, 0.6);
    }

        .text-container {
            position: relative;
            z-index: 1;
            background-color: rgba(0, 0, 0, 0.6);
        }

    details {
        width: 100%;
        max-width: 772px;
        padding: 1rem;
        border: 2px solid;
        border-radius: 25px;
        transition: max-height 0.3s ease-out;
    }
        details[open] {
            max-width: 772px;
        }

    .functions-card{
        min-height: 475px; 
        max-height: 475px;
    }
    @@media(max-width: 540px){
        section{
            flex-direction: column-reverse !important;
